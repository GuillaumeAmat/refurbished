# Camera Dynamics
# Enable camera dynamics for both players
# When enabled, the camera follows the players smoothly
# When disabled, the camera is static
NUXT_PUBLIC_CAMERA_DYNAMICS_ENABLED=false

# Keyboard Fallback
# Enable keyboard fallback for both players
# When enabled, Player 1 uses WASD/ZQSD keys, Player 2 uses arrow keys
# When disabled, game pauses when any gamepad unplugs
NUXT_PUBLIC_KEYBOARD_FALLBACK_ENABLED=true

# Onboarding Circles
# Show animated onboarding circles to guide players through the game steps
NUXT_PUBLIC_ONBOARDING_ENABLED=false

# Refresh Rate Guard
# When enabled, ticks are capped to the detected display refresh rate
# When disabled, ticks fire on every requestAnimationFrame call
NUXT_PUBLIC_REFRESH_RATE_GUARD_ENABLED=false

# Leaderboard Auto Refresh
# When enabled, scores reload every LEADERBOARD_REFRESH_MS ms
NUXT_PUBLIC_LEADERBOARD_AUTO_REFRESH_ENABLED=false

# Upstash Redis (score persistence)
# Get these from https://console.upstash.com or `vercel env pull`
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
